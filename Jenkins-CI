pipeline {

    agent any

    environment {
    GIT_BRANCH = "main"

    DOCKER_USER = "chilukurir"

    BACKEND_IMAGE = "${DOCKER_USER}/chilukuri-backend"

    FRONTEND_IMAGE = "${DOCKER_USER}/chilukuri-frontend"

    SONAR_PROJECT_KEY = "samurai-ecommerce-store"

    SONAR_HOST = "http://13.127.4.112:9000"
}

stages {

        stage('Checkout') {
            steps {
                git branch: "${GIT_BRANCH}",
                    credentialsId: 'github',
                    url: 'https://github.com/Rajesh-210/samurai-themed-e-commerce-store.git'

                script {
                    def shortSha = sh(
                        script: 'git rev-parse --short=7 HEAD',
                        returnStdout: true
                   ).trim()

                   env.IMAGE_TAG = "sha-${shortSha}"
                   echo "Generated Image Tag: ${env.IMAGE_TAG}"

               }    

            }
       }

       stage('Build Application') {
           steps {

                echo "Building Backend..."

                dir('backend') {
                    sh '''
                       python3 -m venv venv
                       . venv/bin/activate
                       pip install --upgrade pip
                       pip install -r requirements.txt
                   '''
               }

               echo "Building Frontend..."

              dir('frontend') {
              sh 'npm install'
              sh 'npm run build'
           }
       }
    }


    stage('SonarQube Scan') {
        steps {

            withSonarQubeEnv('SonarQube') {

                sh """
                ${tool 'SonarScanner'}/bin/sonar-scanner \
                -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                -Dsonar.projectName="Samurai E-Commerce Store" \
                -Dsonar.sources=backend,frontend/src \
                -Dsonar.host.url=${SONAR_HOST} \
                -Dsonar.python.version=3 \
                -Dsonar.exclusions=frontend/node_modules/**,frontend/dist/**,backend/venv/**,backend/__pycache__/**,database/**
                """
           }
       }
   }


   stage('Quality Gate') {
       steps {
           timeout(time: 5, unit: 'MINUTES') {
               waitForQualityGate abortPipeline: true
           }
       }
   }

   stage('Docker Build') {
       steps {
           sh """
                echo "🔨 Building Backend..."
                docker build -t ${BACKEND_IMAGE}:${env.IMAGE_TAG} ./backend

                echo "🔨 Building Frontend..."
                docker build -t ${FRONTEND_IMAGE}:${env.IMAGE_TAG} ./frontend

                echo "Built Images:"
                docker images | grep chilukuri
            """
       }
   }

    stage('Image Scan - Trivy') {
            steps {
                sh """
                    mkdir -p reports/trivy

                    echo "🔍 Scanning backend image..."
                    trivy image \
                      --exit-code 0 \
                      --severity CRITICAL,HIGH \
                      --ignore-unfixed \
                      --format table \
                      --output reports/trivy/backend-scan.txt \
                      ${BACKEND_IMAGE}:${env.IMAGE_TAG}

                    echo "🔍 Scanning frontend image..."
                    trivy image \
                      --exit-code 0 \
                      --severity CRITICAL,HIGH \
                      --format table \
                      --output reports/trivy/frontend-scan.txt \
                      ${FRONTEND_IMAGE}:${env.IMAGE_TAG}

                    echo "✅ Trivy scans passed"
                """
            }
        }

        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo "\$DOCKER_PASS" | docker login -u "\$DOCKER_USER" --password-stdin

                        echo "⬆️  Pushing backend..."
                        docker push ${BACKEND_IMAGE}:${env.IMAGE_TAG}

                        echo "⬆️  Pushing frontend..."
                        docker push ${FRONTEND_IMAGE}:${env.IMAGE_TAG}

                        echo "✅ Both images pushed to Docker Hub"
                        docker logout
                    """
                }
            }
        }

        stage('Publish Reports') {
            steps {
                echo "📋 Archiving scan reports..."
            }
            post {
                always {
                    archiveArtifacts artifacts: 'reports/**/*', allowEmptyArchive: true
                }
            }
        }
        
   }


   post {

    success {
        echo "Pipeline completed successfully."
    }

    failure {
        echo "Pipeline failed. Check the logs."
    }

    always {

        archiveArtifacts artifacts: 'reports/**/*',
                          allowEmptyArchive: true

        cleanWs()
    }
}


    
}
